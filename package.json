{
  "name": "project-preview",
  "version": "1.0.0",
  "description": "Lightweight local project file preview server for in-app browser",
  "main": "dist/server/index.js",
  "type": "module",
  "homepage": "https://github.com/Ruczhutao/codex-file-tree#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ruczhutao/codex-file-tree.git"
  },
  "bugs": {
    "url": "https://github.com/Ruczhutao/codex-file-tree/issues"
  },
  "bin": {
    "project-preview": "./dist/server/index.js"
  },
  "scripts": {
    "dev": "tsx src/server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "keywords": [
    "codex",
    "preview",
    "file-tree",
    "browser",
    "local"
  ],
  "author": "Zhutao",
  "license": "MIT",
  "dependencies": {
    "@codemirror/lang-css": "^6.3.0",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/lang-python": "^6.1.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.34.1",
    "@fastify/static": "^9.1.3",
    "@uiw/codemirror-theme-github": "^4.23.5",
    "@uiw/react-codemirror": "^4.23.5",
    "fastify": "^5.8.5",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.5.4",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.13.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0",
    "vite": "^7.3.3",
    "vitest": "^4.1.5"
  }
}
